{
  "name": "v0-sdk",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "generate": "bun --filter v0 generate && bun --filter @v0-sdk/ai-tools generate",
    "build": "bun --filter v0 build && bun --filter @v0-sdk/ai-tools build",
    "typecheck": "bun --filter v0 typecheck && bun --filter @v0-sdk/ai-tools typecheck",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0"
  }
}
