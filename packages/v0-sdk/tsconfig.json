{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "exactOptionalPropertyTypes": false,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*.ts"]
}
