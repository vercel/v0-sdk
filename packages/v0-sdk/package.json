{
  "name": "v0",
  "version": "1.0.0",
  "description": "TypeScript SDK for the v0 Platform API",
  "keywords": [
    "ai",
    "sdk",
    "v0",
    "vercel"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel/v0-sdk.git",
    "directory": "packages/v0-sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsdown",
    "typecheck": "tsc",
    "prepublishOnly": "bun run generate && bun run build"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@vercel/oidc": "^3.5.0",
    "jsondiffpatch": "^0.6.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@hey-api/openapi-ts": "0.94.3",
    "@tsconfig/strictest": "^2.0.8",
    "publint": "^0.3.18",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  }
}
