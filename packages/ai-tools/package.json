{
  "name": "@v0-sdk/ai-tools",
  "version": "3.0.0",
  "description": "AI SDK tools for the v0 Platform API",
  "keywords": [
    "ai",
    "sdk",
    "tools",
    "v0",
    "vercel"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel/v0-sdk.git",
    "directory": "packages/ai-tools"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate": "bun src/scripts/generate.ts",
    "build": "tsdown",
    "typecheck": "tsc",
    "test": "bun test",
    "prepublishOnly": "bun run generate && bun run build"
  },
  "dependencies": {
    "v0": "workspace:*",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "latest",
    "ai": "^5.0.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "ai": "^5.0.0"
  }
}
